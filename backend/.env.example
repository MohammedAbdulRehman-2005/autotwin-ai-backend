# ══════════════════════════════════════════════════════
# AutoTwin AI — Environment Variables Example
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
APP_NAME=AutoTwin AI
APP_VERSION=1.0.0
DEBUG=true

# ── Security ─────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-32-chars-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Supabase PostgreSQL ───────────────────────────────
# Supabase Dashboard → Project Settings → Database → URI (Transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# ── Supabase API ──────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_STORAGE_BUCKET=invoices

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=["https://autotwin-one.vercel.app","http://localhost:3000"]

# ── Confidence Thresholds ────────────────────────────
HIGH_CONFIDENCE_THRESHOLD=0.95
MEDIUM_CONFIDENCE_THRESHOLD=0.70
