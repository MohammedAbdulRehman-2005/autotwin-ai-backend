# ══════════════════════════════════════════════════════
# AutoTwin AI — Environment Variables Example
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
APP_NAME=AutoTwin AI
APP_VERSION=1.0.0
DEBUG=true

# ── Security ─────────────────────────────────────────
# IMPORTANT: Replace with a secure random string (min 32 chars) in production.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-32-chars-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── MongoDB ───────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Docker: mongodb://autotwin:autotwin_secret@mongodb:27017/autotwin?authSource=admin
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/autotwin
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=autotwin

# ── Redis (optional — reserved for future caching) ───
# REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=["https://autotwin-one.vercel.app","http://localhost:3000"]

# ── Confidence Thresholds ────────────────────────────
HIGH_CONFIDENCE_THRESHOLD=0.95
MEDIUM_CONFIDENCE_THRESHOLD=0.70
